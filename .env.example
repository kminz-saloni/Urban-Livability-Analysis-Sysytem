# UrbanPulse IQ - Backend Environment Variables

# FastAPI Configuration
ENVIRONMENT=development
DEBUG=True

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/urbanpulse_db
SQLALCHEMY_ECHO=True

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Analytics Configuration
DATA_PATH=data/urbanpulse_data.csv
